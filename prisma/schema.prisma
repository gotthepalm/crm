datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// ENUMS

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum VacancyStatus {
  OPEN
  IN_PROGRESS
  PAUSED
  CLOSED
}

enum CandidateStatus {
  NEW
  SCREENING
  INTERVIEW
  TECH_INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum InterviewType {
  HR
  TECH
  LIVE_CODING
  SYSTEM_DESIGN
  BEHAVIORAL
  FINAL
  OTHER
}

// AUTH.JS MODELS

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  Authenticator Authenticator[]

  userCrm UserCrm?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

// CRM MODELS

model UserCrm {
  id         String      @id @default(cuid())
  userId     String      @unique
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vacancies  Vacancy[]
  candidates Candidate[]
  sources    Source[]
  meetings   Meeting[]
}

model Candidate {
  id       Int             @id @default(autoincrement())
  name     String
  position String?
  status   CandidateStatus

  age                     Int?
  email                   String?
  phone                   String?
  location                String?
  skills                  String?
  salaryExpectationBottom Int?
  salaryExpectationTop    Int?
  experienceYears         Int?

  resumeUrl    String?
  linkedinUrl  String?
  gitHubUrl    String?
  portfolioUrl String?
  note         String?
  meetings     Meeting[]

  vacancyId Int?
  vacancy   Vacancy? @relation(fields: [vacancyId], references: [id])

  userCrmId String
  userCrm   UserCrm @relation(fields: [userCrmId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vacancy {
  id              Int             @id @default(autoincrement())
  position        String
  description     String?
  location        String?
  employmentType  EmploymentType?
  salaryFrom      Int?
  salaryTo        Int?
  experienceYears Int?
  status          VacancyStatus
  candidates      Candidate[]
  meetings        Meeting[]
  userCrmId       String
  userCrm         UserCrm         @relation(fields: [userCrmId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Source {
  id   Int     @id @default(autoincrement())
  name String
  url  String
  note String?

  userCrmId String
  userCrm   UserCrm @relation(fields: [userCrmId], references: [id], onDelete: Cascade)
}

model Meeting {
  id            Int           @id @default(autoincrement())
  date          String
  time          String
  url           String?
  interviewType InterviewType
  note          String?
  interviewers  String[]

  candidateId Int?
  vacancyId   Int?
  candidate   Candidate? @relation(fields: [candidateId], references: [id])
  vacancy     Vacancy?   @relation(fields: [vacancyId], references: [id])

  userCrmId String
  userCrm   UserCrm @relation(fields: [userCrmId], references: [id], onDelete: Cascade)
}
